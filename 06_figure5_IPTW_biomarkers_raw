source("00_config.R"); source("01_common_definitions.R")
od<-file.path(OUT_DIR,"figure5_biomarkers_raw"); dir.create(od,recursive=TRUE,showWarnings=FALSE)
logf<-file.path(od,"figure5_progress.log"); cat(format(Sys.time()),"| Figure 5 aggregate/raw script started\n",file=logf,append=FALSE)
fig5tab<-file.path(INTERNAL_OUTPUT_DIR,"Figure_5_longitudinal_markers_IPTW_no_baseline_marker_adjustment","tables")
# fallback: some users keep the combined tables directly under manuscript folder
if(!file.exists(file.path(fig5tab,"all_marker_summary_effects_combined.csv"))) fig5tab<-INTERNAL_OUTPUT_DIR
sum_path<-file.path(fig5tab,"all_marker_summary_effects_combined.csv")
land_path<-file.path(fig5tab,"all_marker_landmark_effect_sizes_combined.csv")
risk_path<-file.path(fig5tab,"all_marker_risk_sets_combined.csv")
grp_path<-file.path(fig5tab,"all_marker_group_summaries_combined.csv")
if(!file.exists(sum_path) || !file.exists(land_path)) stop("Final Figure 5 combined result files not found. Run final Figure 5 analysis first or place combined tables in the Figure 5 tables folder.")
sumdf<-readr::read_csv(sum_path,show_col_types=FALSE)
land<-readr::read_csv(land_path,show_col_types=FALSE)
if(file.exists(risk_path)) file.copy(risk_path,file.path(od,"figure5_risk_sets_raw.csv"),overwrite=TRUE)
if(file.exists(grp_path)) file.copy(grp_path,file.path(od,"figure5_group_summaries_raw.csv"),overwrite=TRUE)
main<-sumdf%>%filter(estimand_type=="Post-baseline uniform time-averaged difference",horizon_start_month==3,horizon_end_month==12)%>%select(marker_id,marker_label,estimate,conf_low,conf_high,p_value,unit)
l12<-land%>%filter(landmark_month==12)%>%select(marker_id,estimate_12=estimate,low_12=conf_low,high_12=conf_high,p_12=p_value)
out<-main%>%left_join(l12,by="marker_id")
write_csv(out,file.path(od,"figure5_marker_summary_raw.csv"))
p<-ggplot(out,aes(estimate,reorder(marker_label,estimate)))+geom_vline(xintercept=0,lty=2)+geom_errorbarh(aes(xmin=conf_low,xmax=conf_high),height=.2)+geom_point()+labs(x="HSG minus non-HSG change",y=NULL,title="Raw biomarker summary")
ggsave(file.path(od,"figure5_raw.png"),p,width=7,height=4,dpi=FIG_DPI)
cat(format(Sys.time()),"| Figure 5 aggregate/raw script finished\n",file=logf,append=TRUE)
file.create(file.path(OUT_DIR,"_DONE_figure5.txt"))
