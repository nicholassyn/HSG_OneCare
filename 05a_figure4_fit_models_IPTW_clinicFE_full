marginal_rate_from_model <- function(fit, vcov_matrix, data, exposure_value, weight_col = "iptw_final") {
newdata<-data
newdata$hsg_exposed<-exposure_value
terms_obj<-stats::delete.response(stats::terms(fit))
X<-stats::model.matrix(terms_obj,data=newdata)
beta<-stats::coef(fit)
beta<-beta[!is.na(beta)]
common_terms<-intersect(colnames(X),names(beta))
if (length(common_terms) == 0) {
  stop("No common model-matrix terms were found for marginal prediction.")
}
X_use<-X[,common_terms,drop=FALSE]
beta_use<-beta[common_terms]
vcov_use<-vcov_matrix[common_terms,common_terms,drop=FALSE]
w<-as.numeric(newdata[[weight_col]])
py<-as.numeric(newdata$person_years)
keep<-!is.na(w) &
  is.finite(w) &
  w > 0 &
  !is.na(py) &
  is.finite(py) &
  py > 0
X_use<-X_use[keep,,drop=FALSE]
w<-w[keep]
py<-py[keep]
eta<-as.numeric(X_use %*% beta_use)
rate_i<-exp(eta)
denominator_py<-sum(w * py)
marginal_rate<-sum(w * py * rate_i) / denominator_py
weighted_X<-X_use * as.numeric(w * py * rate_i)
derivative<-colSums(weighted_X) / denominator_py
list(rate=marginal_rate,derivative=derivative,vcov=vcov_use)
}
estimate_ird_quasipoisson<-function(
  analysis_df,
  endpoint_id,
  endpoint_label,
  endpoint_domain,
  subgroup_id,
  subgroup_label
) {
df<-analysis_df %>% filter(!is.na(hsg_exposed),!is.na(events),!is.na(person_years),person_years > 0,!is.na(iptw_final),is.finite(iptw_final),iptw_final > 0)%>% mutate(hsg_exposed=as.integer(hsg_exposed),events=as.numeric(events),person_years=as.numeric(person_years),iptw_final=as.numeric(iptw_final),clinic=dplyr::if_else(is.na(as.character(clinic))| stringr::str_squish(as.character(clinic))=="","Unknown clinic",stringr::str_squish(as.character(clinic))),clinic_fixed_effect=factor(clinic))
n_total<-nrow(df)
n_hsg<-sum(df$hsg_exposed == 1)
n_nonhsg<-sum(df$hsg_exposed == 0)
n_clinics<-dplyr::n_distinct(df$clinic_fixed_effect)
py_total<-sum(df$person_years,na.rm=TRUE)
py_hsg<-sum(df$person_years[df$hsg_exposed == 1],na.rm=TRUE)
py_nonhsg<-sum(df$person_years[df$hsg_exposed == 0],na.rm=TRUE)
events_total<-sum(df$events,na.rm=TRUE)
events_hsg<-sum(df$events[df$hsg_exposed == 1],na.rm=TRUE)
events_nonhsg<-sum(df$events[df$hsg_exposed == 0],na.rm=TRUE)
weighted_events_hsg<-sum(df$iptw_final[df$hsg_exposed == 1] * df$events[df$hsg_exposed == 1],na.rm=TRUE)
weighted_events_nonhsg<-sum(df$iptw_final[df$hsg_exposed == 0] * df$events[df$hsg_exposed == 0],na.rm=TRUE)
weighted_py_hsg<-sum(df$iptw_final[df$hsg_exposed == 1] * df$person_years[df$hsg_exposed == 1],na.rm=TRUE)
weighted_py_nonhsg<-sum(df$iptw_final[df$hsg_exposed == 0] * df$person_years[df$hsg_exposed == 0],na.rm=TRUE)
weighted_empirical_rate_hsg<-ifelse(weighted_py_hsg > 0,weighted_events_hsg / weighted_py_hsg,NA_real_)
weighted_empirical_rate_nonhsg<-ifelse(weighted_py_nonhsg > 0,weighted_events_nonhsg / weighted_py_nonhsg,NA_real_)
base_result<-tibble(endpoint_id=endpoint_id,endpoint_label=endpoint_label,endpoint_domain=endpoint_domain,subgroup_id=subgroup_id,subgroup_label=subgroup_label,n_total=n_total,n_hsg=n_hsg,n_nonhsg=n_nonhsg,n_clinics=n_clinics,person_years_total=py_total,person_years_hsg=py_hsg,person_years_nonhsg=py_nonhsg,events_total=events_total,events_hsg=events_hsg,events_nonhsg=events_nonhsg,weighted_empirical_rate_hsg_per_py=weighted_empirical_rate_hsg,weighted_empirical_rate_nonhsg_per_py=weighted_empirical_rate_nonhsg,weighted_empirical_ird_per_py=weighted_empirical_rate_hsg - weighted_empirical_rate_nonhsg,model_rate_hsg_per_py=NA_real_,model_rate_nonhsg_per_py=NA_real_,model_ird_per_py=NA_real_,model_ird_se_per_py=NA_real_,model_ird_ci_low_per_py=NA_real_,model_ird_ci_high_per_py=NA_real_,model_ird_p_value=NA_real_,model_status=NA_character_,outcome_model_clinic_fixed_effect=FALSE,outcome_model_vcov_type=NA_character_,zero_event_continuity_applied=FALSE,zero_event_continuity_note=NA_character_)
if (n_hsg < MIN_PATIENTS_PER_ARM || n_nonhsg < MIN_PATIENTS_PER_ARM) {
  return(
  base_result %>% mutate(model_status=paste0("Not estimable: fewer than ",MIN_PATIENTS_PER_ARM," patients in at least one exposure arm"))
  )
}
if (py_hsg < MIN_PERSON_YEARS_PER_ARM || py_nonhsg < MIN_PERSON_YEARS_PER_ARM) {
  return(
  base_result %>% mutate(model_status=paste0("Not estimable: fewer than ",MIN_PERSON_YEARS_PER_ARM," person-years in at least one exposure arm"))
  )
}
if (events_total == 0) {
  return(
  base_result %>% mutate(model_rate_hsg_per_py=0,model_rate_nonhsg_per_py=0,model_ird_per_py=0,model_status="Not estimable: zero events in both exposure arms")
  )
}
df<-df %>% mutate(events_model=events)
zero_event_notes<-character(0)
zero_event_correction_applied<-FALSE
if (APPLY_ZERO_EVENT_CONTINUITY_FOR_MODEL_FITTING) {
  if (events_hsg == 0 && n_hsg > 0) {
  df<-df %>% mutate(events_model=ifelse(hsg_exposed==1,events_model + ZERO_EVENT_CONTINUITY_TOTAL / n_hsg,events_model))
  zero_event_correction_applied<-TRUE
zero_event_notes<-c(zero_event_notes,paste0("HSG arm had zero observed events; added total continuity correction of ",ZERO_EVENT_CONTINUITY_TOTAL," event for model fitting only"))
  }
  if (events_nonhsg == 0 && n_nonhsg > 0) {
  df<-df %>% mutate(events_model=ifelse(hsg_exposed==0,events_model + ZERO_EVENT_CONTINUITY_TOTAL / n_nonhsg,events_model))
  zero_event_correction_applied<-TRUE
zero_event_notes<-c(zero_event_notes,paste0("Non-HSG arm had zero observed events; added total continuity correction of ",ZERO_EVENT_CONTINUITY_TOTAL," event for model fitting only"))
  }
}
rhs_terms <- c("hsg_exposed")
if (OUTCOME_MODEL_INCLUDE_COVARIATES) {
rhs_terms<-c(rhs_terms,"splines::ns(age_at_reference, df = 3)","gender_group","citizenship_group","ethnicity_group","chas_group","chronic_disease_count_capped")
}
clinic_fixed_effect_used<-isTRUE(OUTCOME_MODEL_INCLUDE_CLINIC_FIXED_EFFECTS) &&
  n_clinics >= MIN_CLINICS_FOR_CLINIC_FIXED_EFFECT
if (clinic_fixed_effect_used) {
  rhs_terms <- c(rhs_terms, "clinic_fixed_effect")
}
outcome_formula<-stats::as.formula(paste0("events_model ~ ",paste(rhs_terms,collapse=" + ")))
fit<-tryCatch(
  {
  glm(
  formula=outcome_formula,
  data=df,
  family = quasipoisson(link = "log"),
  offset=log(person_years),
  weights=iptw_final,
  control=glm.control(maxit=200)
  )
  },
  error=function(e) {
  e
  }
