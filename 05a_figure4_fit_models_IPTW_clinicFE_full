row_any_present<-function(data,candidate_columns) {
present_columns<-intersect(candidate_columns,names(data))
if (length(present_columns) == 0) {
  return(rep(FALSE,nrow(data)))
}
present_matrix<-vapply(
  present_columns,
  function(column_name) {
  is_present(data[[column_name]])
  },
  logical(nrow(data))
)
if (is.null(dim(present_matrix))) {
  present_matrix<-matrix(present_matrix,ncol=1)
}
rowSums(present_matrix,na.rm=TRUE) > 0
}
