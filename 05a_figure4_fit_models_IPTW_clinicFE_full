escape_regex<-function(x) {
stringr::str_replace_all(
  x,
  "([.|()\\^{}+$*?\\[\\]\\\\])",
  "\\\\\\1"
)
}
row_any_vaccination_code<-function(data,candidate_columns,included_codes) {
present_columns<-intersect(candidate_columns,names(data))
if (length(present_columns) == 0) {
  return(rep(FALSE,nrow(data)))
}
included_codes<-unique(stringr::str_to_upper(stringr::str_squish(included_codes)))
included_codes <- included_codes[!is.na(included_codes) & included_codes != ""]
included_codes<-included_codes[order(nchar(included_codes),decreasing=TRUE)]
included_codes_escaped<-escape_regex(included_codes)
code_pattern<-paste0("(^|[^A-Z0-9])(",paste(included_codes_escaped,collapse="|"),")([^A-Z0-9]|$)")
code_matrix<-vapply(
  present_columns,
  function(column_name) {
  x_chr<-stringr::str_to_upper(stringr::str_squish(as.character(data[[column_name]])))
  x_chr[is.na(x_chr)] <- ""
  stringr::str_detect(x_chr,code_pattern)
  },
  logical(nrow(data))
)
if (is.null(dim(code_matrix))) {
  code_matrix<-matrix(code_matrix,ncol=1)
}
rowSums(code_matrix,na.rm=TRUE) > 0
}
