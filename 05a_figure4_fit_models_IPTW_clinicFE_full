  )
}
common_terms<-intersect(names(rate_hsg$derivative),names(rate_nonhsg$derivative))
deriv_diff<-rate_hsg$derivative[common_terms] - rate_nonhsg$derivative[common_terms]
vcov_use<-robust_vcov[common_terms,common_terms,drop=FALSE]
ird<-rate_hsg$rate - rate_nonhsg$rate
