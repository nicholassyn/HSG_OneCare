term_is_usable<-function(data,term) {
if (stringr::str_detect(term, "splines::ns\\(")) {
  return(
  "age_at_reference" %in% names(data) &&
  sum(!is.na(data$age_at_reference)) >= 20 &&
  length(unique(data$age_at_reference[!is.na(data$age_at_reference)])) >= 5
  )
}
if (!term %in% names(data)) {
  return(FALSE)
}
x<-data[[term]]
if (is.factor(x) || is.character(x)) {
  x_chr<-as.character(x)
  x_chr[is.na(x_chr) | x_chr == ""] <- "Unknown"
  return(length(unique(x_chr)) >= 2)
}
x_num<-suppressWarnings(as.numeric(x))
return(
  sum(!is.na(x_num)) >= 20 &&
  is.finite(stats::var(x_num,na.rm=TRUE)) &&
  stats::var(x_num,na.rm=TRUE) > 0
)
}
