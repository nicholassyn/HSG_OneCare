fmt_sig3<-function(x) {
out<-rep(NA_character_,length(x))
keep<-!is.na(x) & is.finite(x)
out[keep]<-vapply(
  x[keep],
  FUN=function(val) {
  if (val == 0) {
  return("0")
  }
  val_sig<-signif(val,3)
  val_cap<-round(val_sig,3)
  formatted<-formatC(
  val_cap,
  format = "f",
  digits=3
  )
  formatted <- sub("0+$", "", formatted)
  formatted <- sub("\\.$", "", formatted)
  formatted
  },
  FUN.VALUE=character(1)
)
out
}
