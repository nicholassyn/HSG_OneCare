  return(
  base_result %>% mutate(model_status=paste0("Model failed: ",conditionMessage(fit)),zero_event_continuity_applied=zero_event_correction_applied,zero_event_continuity_note=ifelse(length(zero_event_notes)==0,NA_character_,paste(zero_event_notes,collapse="; ")))
  )
}
