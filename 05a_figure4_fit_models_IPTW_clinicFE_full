calculate_axis_window<-function(ci_low,ci_high,estimate) {
finite_low<-ci_low[is.finite(ci_low)]
finite_high<-ci_high[is.finite(ci_high)]
finite_est<-estimate[is.finite(estimate)]
finite_all<-c(finite_low,finite_high,finite_est)
if (length(finite_all) == 0) {
  return(
list(axis_min=-1,axis_max=1)
  )
}
min_low<-min(finite_low,finite_est,0,na.rm=TRUE)
max_high<-max(finite_high,finite_est,0,na.rm=TRUE)
if (!is.finite(min_low)) min_low<-0
if (!is.finite(max_high)) max_high<-1
if (length(finite_low) > 0 && all(finite_low >= 0,na.rm=TRUE)) {
  axis_min<-0
  axis_max<-max_high * 1.05
} else if (length(finite_high) > 0 && all(finite_high <= 0,na.rm=TRUE)) {
  axis_min<-min_low * 1.05
  axis_max<-0
} else {
  raw_range<-max_high - min_low
  if (!is.finite(raw_range) || raw_range <= 0) {
  raw_range<-max(abs(finite_all),na.rm=TRUE)
  if (!is.finite(raw_range) || raw_range <= 0) {
  raw_range<-1
  }
  }
  axis_min<-min_low - 0.05 * raw_range
  axis_max<-max_high + 0.05 * raw_range
}
if (axis_min == axis_max) {
  axis_min<-axis_min - 0.5
  axis_max<-axis_max + 0.5
}
list(axis_min=axis_min,axis_max=axis_max)
}
nice_axis_breaks<-function(
  axis_min,
  axis_max,
  n_breaks=X_AXIS_N_BREAKS,
  rounding_unit=X_AXIS_ROUNDING_UNIT
) {
if (!is.finite(axis_min) || !is.finite(axis_max) || axis_max <= axis_min) {
  return(c(0,rounding_unit,2 * rounding_unit))
}
tick_min<-if (axis_min > -rounding_unit) {
  0
} else {
  floor(axis_min / rounding_unit) * rounding_unit
}
tick_max<-round(axis_max / rounding_unit) * rounding_unit
if (!is.finite(tick_max)) {
  tick_max<-tick_min + rounding_unit * (n_breaks - 1)
}
if (tick_max <= tick_min) {
  tick_max<-ceiling(axis_max / rounding_unit) * rounding_unit
}
if (tick_max <= tick_min) {
  tick_max<-tick_min + rounding_unit * (n_breaks - 1)
}
raw_step<-(tick_max - tick_min) / (n_breaks - 1)
step<-max(
  rounding_unit,
  round(raw_step / rounding_unit) * rounding_unit
)
breaks<-tick_min + step * 0:(n_breaks - 1)
if (max(breaks,na.rm=TRUE) < tick_max) {
  step<-ceiling(raw_step / rounding_unit) * rounding_unit
  step<-max(step,rounding_unit)
  breaks<-tick_min + step * 0:(n_breaks - 1)
}
round(breaks,10)
}
