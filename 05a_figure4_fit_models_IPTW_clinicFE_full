robust_vcov<-tryCatch(
  {
  if (
  isTRUE(OUTCOME_MODEL_USE_CLUSTER_ROBUST_BY_CLINIC) &&
  n_clinics >= MIN_CLINICS_FOR_CLUSTER_ROBUST_SE
  ) {
  vcov_type_used <- paste0("Clinic-clustered sandwich vcovCL (", ROBUST_VCOV_TYPE, ")")
sandwich::vcovCL(fit,cluster=df$clinic_fixed_effect,type=ROBUST_VCOV_TYPE)
  } else {
  vcov_type_used <- paste0("Heteroskedasticity-robust sandwich vcovHC (", ROBUST_VCOV_TYPE, ")")
  sandwich::vcovHC(fit,type=ROBUST_VCOV_TYPE)
  }
  },
  error=function(e) {
  vcov_type_used <<- "Classical model vcov fallback"
  stats::vcov(fit)
  }
)
if (is.null(dim(robust_vcov))) {
  vcov_type_used <- "Classical model vcov fallback"
  robust_vcov<-stats::vcov(fit)
}
rate_hsg<-tryCatch(
  marginal_rate_from_model(
  fit=fit,
  vcov_matrix=robust_vcov,
  data=df,
  exposure_value=1,
  weight_col = "iptw_final"
  ),
  error=function(e) {
  e
  }
)
rate_nonhsg<-tryCatch(
  marginal_rate_from_model(
  fit=fit,
