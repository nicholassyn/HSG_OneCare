weighted_mean<-function(x,w) {
keep<-!is.na(x) & !is.na(w) & is.finite(w) & w > 0
if (!any(keep)) {
  return(NA_real_)
}
sum(w[keep] * x[keep]) / sum(w[keep])
}
weighted_var<-function(x,w) {
keep<-!is.na(x) & !is.na(w) & is.finite(w) & w > 0
if (sum(keep) < 2) {
  return(NA_real_)
}
m<-weighted_mean(x[keep],w[keep])
sum(w[keep] * (x[keep] - m)^2) / sum(w[keep])
}
smd_numeric<-function(x,treat,w=NULL) {
treat<-as.integer(treat)
if (is.null(w)) {
  w<-rep(1,length(x))
}
x<-as.numeric(x)
m1<-weighted_mean(x[treat == 1],w[treat == 1])
m0<-weighted_mean(x[treat == 0],w[treat == 0])
v1<-weighted_var(x[treat == 1],w[treat == 1])
v0<-weighted_var(x[treat == 0],w[treat == 0])
denom<-sqrt((v1 + v0) / 2)
if (is.na(denom) || denom <= 0) {
  return(NA_real_)
}
(m1 - m0) / denom
}
