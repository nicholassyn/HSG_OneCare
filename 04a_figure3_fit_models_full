filter_model_covariates <- function(model_df, candidate_terms) {
 if (length(candidate_terms) == 0) {
  return(character(0))
 }
 keep_terms <- character(0)
 for (term in candidate_terms) {
  if (!term %in% names(model_df)) {
   next
  }
  x <- as.numeric(model_df[[term]])
  n_nonmissing <- sum(!is.na(x))
  var_x <- suppressWarnings(stats::var(x, na.rm = TRUE))
  if (
   n_nonmissing >= MIN_NONMISSING_MONTHS_FOR_COVARIATE &&
   is.finite(var_x) &&
   !is.na(var_x) &&
   var_x > 0.0000000001
  ) {
   keep_terms <- c(keep_terms, term)
  }
 }
 keep_terms
}
