robust_predict <- function(fit_obj, newdata) {
 fit <- fit_obj$fit
 vc <- fit_obj$robust_vcov
 terms_obj <- stats::delete.response(stats::terms(fit))
 X <- stats::model.matrix(terms_obj, data = newdata)
 beta <- stats::coef(fit)
 beta <- beta[!is.na(beta)]
 common_terms <- intersect(colnames(X), names(beta))
 X_use <- X[, common_terms, drop = FALSE]
 beta_use <- beta[common_terms]
 vc_use <- vc[common_terms, common_terms, drop = FALSE]
 fit_value <- as.numeric(X_use %*% beta_use)
 pred_var <- rowSums((X_use %*% vc_use) * X_use)
 pred_se <- sqrt(pmax(pred_var, 0))
 df_resid <- max(stats::df.residual(fit), 1)
 critical <- stats::qt(0.975, df = df_resid)
 tibble::tibble(
  fit = fit_value,
  se = pred_se,
  conf_low = fit_value - critical * pred_se,
  conf_high = fit_value + critical * pred_se
 )
}
