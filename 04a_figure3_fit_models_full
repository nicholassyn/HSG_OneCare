parse_mixed_date <- function(x) {
 if (inherits(x, "Date")) {
  return(x)
 }
 if (inherits(x, "POSIXct") || inherits(x, "POSIXlt")) {
  return(as.Date(x))
 }
 if (is.numeric(x)) {
  out <- rep(as.Date(NA), length(x))
  valid_excel <- !is.na(x) & x > 20000 & x < 70000
  out[valid_excel] <- as.Date(x[valid_excel], origin = "1899-12-30")
  return(out)
 }
 x_chr <- as.character(x)
 x_chr <- stringr::str_squish(x_chr)
 x_chr[
  is.na(x_chr) |
   x_chr == "" |
   stringr::str_to_upper(x_chr) %in% c(
    "NA", "N/A", "NULL", "NONE", "NIL", "NAN",
    "UNKNOWN", "MISSING", "NOT AVAILABLE", "NOT APPLICABLE"
   )
 ] <- NA_character_
 parsed <- suppressWarnings(
  lubridate::parse_date_time(
   x_chr,
   orders = c(
    "ymd HMS", "ymd HM", "ymd",
    "dmy HMS", "dmy HM", "dmy",
    "mdy HMS", "mdy HM", "mdy",
    "d b Y", "d B Y", "d b y", "d B y",
    "d-b-Y", "d-B-Y", "d-b-y", "d-B-y",
    "b d Y", "B d Y", "b d y", "B d y",
    "m/d/Y", "m/d/y",
    "d/m/Y", "d/m/y",
    "Y/m/d",
    "Y-m-d"
   ),
   tz = "UTC",
   quiet = TRUE
  )
 )
 out <- as.Date(parsed)
 numeric_x <- suppressWarnings(as.numeric(x_chr))
 excel_idx <- is.na(out) & !is.na(numeric_x) & numeric_x > 20000 & numeric_x < 70000
 if (any(excel_idx, na.rm = TRUE)) {
  out[excel_idx] <- as.Date(numeric_x[excel_idx], origin = "1899-12-30")
 }
 out
}
is_present <- function(x) {
 if (inherits(x, "Date")) {
  return(!is.na(x))
 }
 if (inherits(x, "POSIXct") || inherits(x, "POSIXlt")) {
  return(!is.na(x))
 }
 x_chr <- as.character(x)
 x_chr <- stringr::str_squish(x_chr)
 x_upper <- stringr::str_to_upper(x_chr)
 !is.na(x_chr) &
  x_chr != "" &
  !(x_upper %in% c(
   "NA", "N/A", "NULL", "NONE", "NIL", "NAN",
   "UNKNOWN", "MISSING", "NOT AVAILABLE", "NOT APPLICABLE"
  ))
}
to_numeric_clean <- function(x) {
 if (is.numeric(x)) {
  return(x)
 }
 x_chr <- as.character(x)
 x_chr <- stringr::str_squish(x_chr)
 x_chr[is.na(x_chr) | x_chr == ""] <- NA_character_
 x_chr <- stringr::str_replace_all(x_chr, ",", "")
 x_chr <- stringr::str_extract(x_chr, "[-+]?[0-9]*\\.?[0-9]+([eE][-+]?[0-9]+)?")
 suppressWarnings(as.numeric(x_chr))
}
