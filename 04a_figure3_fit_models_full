  pred_df$fitted,
  pred_df$counterfactual
 )
 y_min <- min(y_values, na.rm = TRUE)
 y_max <- max(y_values, na.rm = TRUE)
 y_abs <- max(abs(c(y_min, y_max)), na.rm = TRUE)
 y_abs_top <- choose_axis_top(y_abs, allow_negative = FALSE)
 p_bottom <- ggplot() +
  geom_hline(
   yintercept = 0,
   linewidth = ITS_ZERO_LINE_WIDTH,
   colour = "#777777"
  ) +
  geom_vline(
   xintercept = HSG_START_DATE,
   linetype = "dashed",
   linewidth = ITS_VLINE_WIDTH,
   colour = "#333333"
  ) +
  geom_ribbon(
   data = pred_df,
   aes(
    x = encounter_month,
    ymin = fitted_low,
    ymax = fitted_high
   ),
   fill = COLOUR_HSG_LIGHT,
   alpha = ITS_CONTROLLED_RIBBON_ALPHA,
   colour = NA,
   show.legend = FALSE
  ) +
  geom_point(
   data = observed_df,
   aes(
    x = encounter_month,
    y = rate_difference_pp,
    alpha = point_alpha
   ),
   size = ITS_POINT_SIZE + 0.1,
   colour = COLOUR_HSG_DARK,
   show.legend = FALSE
  ) +
  geom_line(
   data = pred_df,
   aes(
    x = encounter_month,
    y = fitted
   ),
   linewidth = ITS_LINEWIDTH,
   colour = COLOUR_HSG_DARK,
   show.legend = FALSE
  ) +
  geom_line(
   data = pred_df %>%
    dplyr::filter(post == 1),
   aes(
    x = encounter_month,
    y = counterfactual
   ),
   linewidth = ITS_COUNTERFACTUAL_LINEWIDTH,
   colour = COLOUR_COUNTERFACTUAL,
   linetype = "longdash",
   show.legend = FALSE
