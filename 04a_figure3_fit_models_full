  x_upper,
  paste0(
   "FOREIGN|FOREIGNER|WORK PASS|WORKPASS|WORK PERMIT|",
   "EMPLOYMENT PASS|\\bE PASS\\b|\\bEP\\b|S PASS|SPASS|",
   "DEPENDANT PASS|DEPENDENT PASS|LONG.?TERM VISIT PASS|LTVP"
  )
 )
