  geom_line(
   data = pred_df,
   aes(
    x = encounter_month,
    y = fitted_plot,
    colour = comparison_group
   ),
   linewidth = ITS_LINEWIDTH,
   show.legend = FALSE
  ) +
  geom_line(
   data = pred_hsg_counterfactual,
   aes(
    x = encounter_month,
    y = counterfactual_plot
   ),
   colour = COLOUR_HSG_LIGHT,
   linewidth = ITS_COUNTERFACTUAL_LINEWIDTH,
   linetype = "longdash",
   show.legend = FALSE
  ) +
  geom_line(
   data = pred_nonhsg_counterfactual,
   aes(
    x = encounter_month,
    y = counterfactual_plot
