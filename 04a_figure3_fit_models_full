  covariate_terms
 ))
 required_cols <- required_cols[required_cols %in% names(model_df)]
 model_df <- model_df %>%
  arrange(encounter_month)
 model_df <- model_df[stats::complete.cases(model_df[, required_cols, drop = FALSE]), , drop = FALSE]
 model_df <- model_df[is.finite(model_df[[weight_col]]) & model_df[[weight_col]] > 0, , drop = FALSE]
 if (nrow(model_df) < MIN_MODEL_MONTHS) {
  return(
   list(
    ok = FALSE,
    reason = paste0("Too few model months: ", nrow(model_df)),
    model_label = model_label
   )
  )
 }
 n_pre <- sum(model_df$post == 0, na.rm = TRUE)
 n_post <- sum(model_df$post == 1, na.rm = TRUE)
 if (n_pre < MIN_PRE_MONTHS || n_post < MIN_POST_MONTHS) {
  return(
   list(
    ok = FALSE,
    reason = paste0(
     "Insufficient pre/post months. Pre=",
     n_pre,
     "; post=",
     n_post
    ),
    model_label = model_label
   )
  )
 }
 covariate_terms <- filter_model_covariates(model_df, covariate_terms)
 rhs_terms <- c("time", "post", "time_after", covariate_terms)
 model_formula <- stats::as.formula(
  paste0(outcome_col, " ~ ", paste(rhs_terms, collapse = " + "))
 )
 model_df$model_weight_internal <- cap_weights(model_df[[weight_col]])
 fit <- tryCatch(
  {
   stats::lm(
    formula = model_formula,
    data = model_df,
    weights = model_weight_internal
   )
  },
  error = function(e) {
   return(NULL)
  }
 )
 if (is.null(fit)) {
  return(
   list(
    ok = FALSE,
    reason = "lm() failed",
    model_label = model_label
   )
  )
 }
 robust_vcov <- tryCatch(
  {
   sandwich::NeweyWest(
    fit,
    lag = NEWEY_WEST_LAG_MONTHS,
    prewhite = FALSE,
    adjust = TRUE
   )
  },
  error = function(e) {
   sandwich::vcovHC(fit, type = "HC1")
  }
 )
 robust_type <- "Newey-West"
 if (is.null(dim(robust_vcov))) {
  robust_vcov <- stats::vcov(fit)
  robust_type <- "Classical lm vcov fallback"
 }
 list(
  ok = TRUE,
  reason = NA_character_,
  fit = fit,
  robust_vcov = robust_vcov,
  model_data = model_df,
  formula = model_formula,
  covariate_terms = covariate_terms,
  model_label = model_label,
  robust_type = robust_type,
  outcome_col = outcome_col,
  weight_col = weight_col,
  n_model_months = nrow(model_df),
  n_pre_months = n_pre,
  n_post_months = n_post
 )
}
linear_combo <- function(fit_obj, contrast_terms, contrast_label) {
 fit <- fit_obj$fit
 vc <- fit_obj$robust_vcov
 beta <- stats::coef(fit)
 beta <- beta[!is.na(beta)]
 vc <- vc[names(beta), names(beta), drop = FALSE]
 L <- rep(0, length(beta))
 names(L) <- names(beta)
 missing_terms <- setdiff(names(contrast_terms), names(beta))
 if (length(missing_terms) > 0) {
  return(
   tibble::tibble(
    contrast = contrast_label,
    estimate = NA_real_,
    std_error = NA_real_,
    conf_low = NA_real_,
    conf_high = NA_real_,
    p_value = NA_real_,
    missing_terms = paste(missing_terms, collapse = "; ")
   )
  )
 }
 L[names(contrast_terms)] <- as.numeric(contrast_terms)
 estimate <- as.numeric(sum(L * beta))
 variance <- as.numeric(t(L) %*% vc %*% L)
 std_error <- sqrt(max(variance, 0))
 df_resid <- max(stats::df.residual(fit), 1)
 critical <- stats::qt(0.975, df = df_resid)
 if (is.finite(std_error) && std_error > 0) {
  t_value <- estimate / std_error
  p_value <- 2 * stats::pt(abs(t_value), df = df_resid, lower.tail = FALSE)
 } else {
  p_value <- NA_real_
 }
 tibble::tibble(
  contrast = contrast_label,
  estimate = estimate,
  std_error = std_error,
  conf_low = estimate - critical * std_error,
  conf_high = estimate + critical * std_error,
  p_value = p_value,
  missing_terms = NA_character_
 )
}
