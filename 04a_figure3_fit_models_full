choose_axis_top <- function(x, allow_negative = FALSE) {
 x <- x[is.finite(x)]
 if (length(x) == 0) {
  return(10)
 }
 max_x <- max(x, na.rm = TRUE)
 if (!allow_negative) {
  max_x <- max(max_x, 0)
 }
 candidates <- c(
  1.5, 3, 5, 7.5, 10, 15, 20, 25, 30, 40, 50,
  60, 75, 90, 100, 125, 150
 )
 out <- candidates[candidates >= max_x]
 if (length(out) == 0) {
  return(ceiling(max_x / 25) * 25)
 }
 out[1]
}
cap_weights <- function(w) {
 w <- as.numeric(w)
 if (!CAP_EXTREME_MODEL_WEIGHTS) {
  return(w)
 }
 finite_w <- w[is.finite(w) & !is.na(w) & w > 0]
 if (length(finite_w) < 5) {
  return(w)
 }
 cap <- as.numeric(stats::quantile(finite_w, probs = WEIGHT_CAP_QUANTILE, na.rm = TRUE))
 pmin(w, cap)
}
