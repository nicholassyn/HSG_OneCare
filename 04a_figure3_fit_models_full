to_yes_no_bool <- function(x) {
 if (is.logical(x)) {
  return(!is.na(x) & x)
 }
 if (is.numeric(x)) {
  return(!is.na(x) & x != 0)
 }
 x_chr <- stringr::str_to_lower(stringr::str_squish(as.character(x)))
 x_chr[is.na(x_chr)] <- ""
 negative <- stringr::str_detect(
  x_chr,
  "^(0|no|false|n|nil|none|not done|not completed|incomplete|negative|absent)$"
 )
 positive <- stringr::str_detect(
  x_chr,
  "^(1|yes|true|y|done|completed|complete|positive|present|recorded)$"
 )
 positive & !negative
}
