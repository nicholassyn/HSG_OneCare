plot_difference_its <- function(process_row, diff_df, diff_prediction_table) {
 process_id <- process_row$process_id
 observed_df <- diff_df %>%
  dplyr::mutate(
   point_alpha = ifelse(model_eligible_month, 0.95, 0.35)
  )
 pred_df <- diff_prediction_table
 y_values <- c(
