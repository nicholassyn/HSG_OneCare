  "Non-HSG" = COLOUR_NONHSG_LIGHT
 )
 p_top <- ggplot() +
  geom_vline(
   xintercept = HSG_START_DATE,
   linetype = "dashed",
   linewidth = ITS_VLINE_WIDTH,
   colour = "#333333"
  ) +
  geom_ribbon(
   data = pred_df,
