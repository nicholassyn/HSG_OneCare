make_time_variables <- function(df) {
 start_month <- lubridate::floor_date(STUDY_START_DATE, unit = "month")
 hsg_start_month <- lubridate::floor_date(HSG_START_DATE, unit = "month")
 intervention_index <- lubridate::interval(start_month, hsg_start_month) %/% months(1)
 df %>%
  mutate(
   month_index = month_index_between(start_month, encounter_month),
   time = as.numeric(month_index),
   post = as.integer(encounter_month >= hsg_start_month),
   time_after = dplyr::if_else(
    post == 1L,
    as.numeric(month_index - intervention_index),
    0
   )
  )
}
select_adjustment_covariates_for_process <- function(denominator_df, process_id) {
 covariate_table <- covariate_specs %>%
  rowwise() %>%
  mutate(
   denominator_missing_rate = ifelse(
    nrow(denominator_df) == 0,
    NA_real_,
    mean(is.na(denominator_df[[covariate]]))
   ),
   denominator_nonmissing_n = ifelse(
    nrow(denominator_df) == 0,
    0L,
    sum(!is.na(denominator_df[[covariate]]))
   ),
   denominator_variance = ifelse(
    nrow(denominator_df) == 0,
    NA_real_,
    suppressWarnings(stats::var(denominator_df[[covariate]], na.rm = TRUE))
   )
  ) %>%
  ungroup() %>%
  mutate(
   process_id = process_id,
   passes_missingness =
    !is.na(denominator_missing_rate) &
    denominator_missing_rate <= COVARIATE_MISSINGNESS_THRESHOLD,
   passes_variance =
    is.finite(denominator_variance) &
    !is.na(denominator_variance) &
    denominator_variance > 0.0000000001,
   selected_for_adjustment =
    passes_missingness &
    passes_variance
  ) %>%
  arrange(priority)
 selected <- covariate_table %>%
  filter(selected_for_adjustment) %>%
  arrange(priority) %>%
  slice_head(n = MAX_ADJUSTMENT_COVARIATES) %>%
  pull(covariate)
 list(
  selected_covariates = selected,
  covariate_table = covariate_table
 )
}
make_monthly_process_summary <- function(process_row, selected_covariates) {
 numerator_col <- process_row$numerator_col
 denominator_col <- process_row$denominator_col
 all_months <- tibble::tibble(
  encounter_month = seq.Date(
   from = lubridate::floor_date(STUDY_START_DATE, unit = "month"),
   to = lubridate::floor_date(STUDY_END_DATE, unit = "month"),
   by = "month"
  )
 )
 all_groups <- tibble::tibble(
  comparison_group = factor(c("Non-HSG", "HSG"), levels = c("Non-HSG", "HSG"))
 )
 denominator_df <- patient_date_encounters %>%
  filter(.data[[denominator_col]])
 if (length(selected_covariates) > 0) {
  monthly_summary <- denominator_df %>%
   group_by(comparison_group, encounter_month) %>%
   summarise(
    denominator = n(),
    numerator = sum(.data[[numerator_col]], na.rm = TRUE),
    across(all_of(selected_covariates), ~ mean_or_na(.x)),
    .groups = "drop"
   )
 } else {
  monthly_summary <- denominator_df %>%
   group_by(comparison_group, encounter_month) %>%
   summarise(
    denominator = n(),
    numerator = sum(.data[[numerator_col]], na.rm = TRUE),
    .groups = "drop"
   )
 }
 monthly_summary <- tidyr::crossing(all_groups, all_months) %>%
  left_join(monthly_summary, by = c("comparison_group", "encounter_month")) %>%
  mutate(
   denominator = tidyr::replace_na(denominator, 0L),
   numerator = tidyr::replace_na(numerator, 0L),
   rate_percent = dplyr::if_else(
    denominator > 0,
    100 * numerator / denominator,
    NA_real_
   ),
   model_eligible_month = denominator >= MIN_DENOMINATOR_PER_MONTH,
   process_id = process_row$process_id,
   process_label = process_row$process_label,
   numerator_col = numerator_col,
   denominator_col = denominator_col,
   denominator_description = process_row$denominator_description,
   numerator_description = process_row$numerator_description
  ) %>%
  make_time_variables()
 monthly_summary
}
make_difference_monthly_data <- function(monthly_summary, selected_covariates) {
 base_cols <- c(
  "encounter_month",
  "month_index",
  "time",
  "post",
  "time_after",
  "denominator",
  "numerator",
  "rate_percent"
 )
 hsg_cols <- c(base_cols, selected_covariates)
 hsg_cols <- hsg_cols[hsg_cols %in% names(monthly_summary)]
 nonhsg_cols <- hsg_cols
 hsg <- monthly_summary %>%
  filter(comparison_group == "HSG") %>%
  select(all_of(hsg_cols))
 hsg_rename_cols <- setdiff(names(hsg), c("encounter_month", "month_index", "time", "post", "time_after"))
 hsg <- hsg %>%
  rename_with(
   .fn = ~ paste0(.x, "_hsg"),
   .cols = all_of(hsg_rename_cols)
  )
 nonhsg <- monthly_summary %>%
  filter(comparison_group == "Non-HSG") %>%
  select(all_of(nonhsg_cols))
 nonhsg_rename_cols <- setdiff(names(nonhsg), c("encounter_month", "month_index", "time", "post", "time_after"))
 nonhsg <- nonhsg %>%
  rename_with(
   .fn = ~ paste0(.x, "_nonhsg"),
   .cols = all_of(nonhsg_rename_cols)
  )
 diff_df <- hsg %>%
  inner_join(
   nonhsg,
   by = c("encounter_month", "month_index", "time", "post", "time_after")
  ) %>%
  mutate(
   rate_difference_pp = rate_percent_hsg - rate_percent_nonhsg,
   p_hsg = (numerator_hsg + 0.5) / (denominator_hsg + 1),
   p_nonhsg = (numerator_nonhsg + 0.5) / (denominator_nonhsg + 1),
   var_hsg_pp = 10000 * p_hsg * (1 - p_hsg) / pmax(denominator_hsg + 1, 1),
   var_nonhsg_pp = 10000 * p_nonhsg * (1 - p_nonhsg) / pmax(denominator_nonhsg + 1, 1),
   diff_variance_pp = var_hsg_pp + var_nonhsg_pp,
   diff_weight = 1 / pmax(diff_variance_pp, 0.000001),
   model_eligible_month =
    denominator_hsg >= MIN_DENOMINATOR_PER_MONTH &
    denominator_nonhsg >= MIN_DENOMINATOR_PER_MONTH
  )
 diff_covariates <- character(0)
 if (length(selected_covariates) > 0) {
  for (covariate in selected_covariates) {
   hsg_cov <- paste0(covariate, "_hsg")
   nonhsg_cov <- paste0(covariate, "_nonhsg")
   diff_cov <- paste0("diff_", covariate)
   if (hsg_cov %in% names(diff_df) && nonhsg_cov %in% names(diff_df)) {
    diff_df[[diff_cov]] <- diff_df[[hsg_cov]] - diff_df[[nonhsg_cov]]
    diff_covariates <- c(diff_covariates, diff_cov)
   }
  }
 }
 list(
  diff_df = diff_df,
  diff_covariates = diff_covariates
 )
}
