make_counterfactual_prediction_data <- function(actual_data) {
 intervention_index <- get_intervention_month_index()
 actual_data <- actual_data %>%
  mutate(
   counterfactual_elapsed_months = pmax(as.numeric(month_index) - intervention_index, 0)
  )
 if (LINEAR_COUNTERFACTUAL_EXTRAPOLATION_MODE == "model_implied_pretrend") {
  effective_elapsed <- actual_data$counterfactual_elapsed_months
 } else if (LINEAR_COUNTERFACTUAL_EXTRAPOLATION_MODE == "implementation_anchor") {
  effective_elapsed <- rep(0, nrow(actual_data))
 } else if (LINEAR_COUNTERFACTUAL_EXTRAPOLATION_MODE == "limited_pretrend") {
  effective_elapsed <- pmin(
   actual_data$counterfactual_elapsed_months,
   COUNTERFACTUAL_MAX_EFFECTIVE_EXTRAPOLATION_MONTHS
  )
 } else if (LINEAR_COUNTERFACTUAL_EXTRAPOLATION_MODE == "smooth_damped_pretrend") {
  effective_elapsed <- COUNTERFACTUAL_MAX_EFFECTIVE_EXTRAPOLATION_MONTHS *
   (1 - 0.5^(actual_data$counterfactual_elapsed_months / COUNTERFACTUAL_DAMPING_HALF_LIFE_MONTHS))
 } else {
  warning(
   "Unknown LINEAR_COUNTERFACTUAL_EXTRAPOLATION_MODE: ",
   LINEAR_COUNTERFACTUAL_EXTRAPOLATION_MODE,
   "; using original model-implied pretrend."
  )
  effective_elapsed <- actual_data$counterfactual_elapsed_months
 }
 effective_elapsed <- ifelse(actual_data$post == 1L, effective_elapsed, 0)
 actual_data %>%
  mutate(
   counterfactual_mode = LINEAR_COUNTERFACTUAL_EXTRAPOLATION_MODE,
   counterfactual_elapsed_months = counterfactual_elapsed_months,
   counterfactual_effective_elapsed_months = effective_elapsed,
   counterfactual_time_used = dplyr::if_else(
    post == 1L,
    as.numeric(intervention_index + effective_elapsed),
    as.numeric(time)
   ),
   time = counterfactual_time_used,
   post = 0L,
   time_after = 0
  )
}
standardize_prediction_covariates <- function(
  prediction_data,
  reference_data,
  covariate_terms,
  weight_col = NULL
) {
 if (!isTRUE(STANDARDIZE_LINEAR_PREDICTION_COVARIATES)) {
  return(prediction_data)
 }
 if (length(covariate_terms) == 0) {
  return(prediction_data)
 }
 covariate_terms <- intersect(covariate_terms, names(prediction_data))
 covariate_terms <- intersect(covariate_terms, names(reference_data))
 if (length(covariate_terms) == 0) {
  return(prediction_data)
 }
 reference_df <- reference_data
 if (PREDICTION_COVARIATE_REFERENCE == "pre_period_weighted_mean") {
  reference_df <- reference_df %>% filter(post == 0)
 }
 if (nrow(reference_df) == 0) {
  reference_df <- reference_data
 }
 w <- rep(1, nrow(reference_df))
 if (!is.null(weight_col) && weight_col %in% names(reference_df)) {
  w_candidate <- as.numeric(reference_df[[weight_col]])
  if (any(is.finite(w_candidate) & !is.na(w_candidate) & w_candidate > 0)) {
   w <- w_candidate
  }
 }
 for (covariate in covariate_terms) {
  x <- as.numeric(reference_df[[covariate]])
  keep <- !is.na(x) & is.finite(x) & !is.na(w) & is.finite(w) & w > 0
  if (any(keep)) {
   prediction_data[[covariate]] <- sum(x[keep] * w[keep]) / sum(w[keep])
  }
 }
 prediction_data
}
bound_group_plot_values <- function(x) {
 x <- as.numeric(x)
 if (isTRUE(BOUND_GROUP_RATE_PLOTS_TO_0_100)) {
  x <- pmin(pmax(x, 0), 100)
 }
 x
}
make_prediction_table <- function(fit_obj, model_kind) {
 if (!isTRUE(fit_obj$ok)) {
  return(tibble::tibble())
 }
 actual_data <- fit_obj$model_data
 covariate_terms <- fit_obj$covariate_terms
 weight_col <- fit_obj$weight_col
 outcome_col <- fit_obj$outcome_col
 actual_prediction_data <- standardize_prediction_covariates(
  prediction_data = actual_data,
  reference_data = actual_data,
  covariate_terms = covariate_terms,
  weight_col = weight_col
 )
 actual_pred <- robust_predict(fit_obj, actual_prediction_data) %>%
  rename(
   fitted = fit,
   fitted_se = se,
   fitted_low = conf_low,
   fitted_high = conf_high
  )
 counterfactual_data <- make_counterfactual_prediction_data(actual_data)
 counterfactual_prediction_data <- standardize_prediction_covariates(
  prediction_data = counterfactual_data,
  reference_data = actual_data,
  covariate_terms = covariate_terms,
  weight_col = weight_col
 )
 counterfactual_pred <- robust_predict(fit_obj, counterfactual_prediction_data) %>%
  rename(
   counterfactual = fit,
   counterfactual_se = se,
   counterfactual_low = conf_low,
   counterfactual_high = conf_high
  )
 out <- bind_cols(
  actual_data,
  actual_pred,
  counterfactual_prediction_data %>%
   select(
    counterfactual_mode,
    counterfactual_elapsed_months,
    counterfactual_effective_elapsed_months,
    counterfactual_time_used
   ),
  counterfactual_pred
 ) %>%
  mutate(
   model_kind = model_kind,
   counterfactual_is_stabilised = LINEAR_COUNTERFACTUAL_EXTRAPOLATION_MODE != "model_implied_pretrend"
  )
 if (!is.null(outcome_col) && outcome_col == "rate_percent") {
  out <- out %>%
   mutate(
    fitted_plot = bound_group_plot_values(fitted),
    fitted_low_plot = bound_group_plot_values(fitted_low),
    fitted_high_plot = bound_group_plot_values(fitted_high),
    counterfactual_plot = bound_group_plot_values(counterfactual),
    counterfactual_low_plot = bound_group_plot_values(counterfactual_low),
    counterfactual_high_plot = bound_group_plot_values(counterfactual_high)
   )
 } else {
  out <- out %>%
   mutate(
    fitted_plot = fitted,
    fitted_low_plot = fitted_low,
    fitted_high_plot = fitted_high,
    counterfactual_plot = counterfactual,
    counterfactual_low_plot = counterfactual_low,
    counterfactual_high_plot = counterfactual_high
   )
 }
 out
}
