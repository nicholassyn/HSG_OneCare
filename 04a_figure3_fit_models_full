  scale_y_continuous(
   limits = c(-y_abs_top, y_abs_top),
   labels = function(x) paste0(x, "%"),
   expand = expansion(mult = c(0.02, 0.05))
  ) +
  labs(
   x = NULL,
   y = expression(Delta~"(%)")
  ) +
  coord_cartesian(clip = "off") +
  theme_its(base_size = ITS_BASE_SIZE) +
  theme(
   legend.position = "none",
   plot.margin = ggplot2::margin(
    t = 18,
    r = 12,
    b = 10,
    l = 10
   )
  ) +
  guides(
   colour = "none",
   fill = "none",
   alpha = "none"
  )
 if (exists(process_id, envir = ITS_TOP_PANEL_STORE, inherits = FALSE)) {
  p_top <- get(process_id, envir = ITS_TOP_PANEL_STORE, inherits = FALSE)
  p_combined <- p_top / p_bottom +
   patchwork::plot_layout(
