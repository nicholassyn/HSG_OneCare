  first_hsg_enrolment_event_date = dplyr::case_when(
   !is.na(raw_first_enrolment_event_date) &
    raw_first_enrolment_event_date >= HSG_START_DATE ~ raw_first_enrolment_event_date,
   !is.na(raw_first_enrolment_event_date) &
    raw_first_enrolment_event_date < HSG_START_DATE &
    !is.na(first_encounter_date) &
    first_encounter_date >= HSG_START_DATE ~ first_encounter_date,
   TRUE ~ as.Date(NA)
  )
 ) %>%
 rowwise() %>%
 mutate(
  first_valid_enrolment_reference_date = safe_min_date(
   c(
    first_hsg_pre_enrolment_event_date,
    first_hsg_enrolment_event_date
   )
  )
 ) %>%
 ungroup() %>%
 mutate(
