    raw_first_enrolment_date_from_field,
    raw_first_enrolment_date_from_status,
    raw_first_enrolment_date_from_kind,
    if (USE_ANNUAL_HEALTH_PLAN_AS_ENROLMENT_EVIDENCE) {
     raw_first_enrolment_date_from_ahp
    } else {
     as.Date(NA)
    }
   )
  ),
  first_deenrolment_event_date = safe_min_date(
   c(
    first_deenrolment_date_from_field,
    first_deenrolment_date_from_status,
    first_deenrolment_date_from_kind
   )
  )
 ) %>%
 ungroup() %>%
 mutate(
  hsg_pre_enrolment_needed =
   !is.na(raw_first_enrolment_event_date) &
   raw_first_enrolment_event_date < HSG_START_DATE &
   !is.na(first_encounter_date) &
   first_encounter_date < HSG_START_DATE,
  first_hsg_pre_enrolment_event_date = dplyr::case_when(
   hsg_pre_enrolment_needed ~ HSG_PRE_ENROLMENT_DATE,
   TRUE ~ as.Date(NA)
