  stringr::str_detect(beta_names,term_regex)
]
if (length(terms_to_test) == 0) {
  return(
tibble::tibble(marker_id=marker_id,marker_label=marker_label,test_label=test_label,terms_tested=NA_character_,n_terms=0L,chisq=NA_real_,df=0L,p_value=NA_real_,p_print="NA",test_status="No matching model terms")
  )
}
