classify_effect_direction<-function(estimate,p_value,lower_is_better) {
if (is.na(estimate) || !is.finite(estimate)) {
  return("Not estimable")
}
significance_label<-ifelse(!is.na(p_value)&& is.finite(p_value)&& p_value < SIGNIFICANCE_ALPHA,"statistically significant","not statistically significant")
if (lower_is_better) {
  if (estimate < 0) {
  return(paste0("Favours HSG greater reduction; ", significance_label))
  }
  if (estimate > 0) {
  return(paste0("Favours non-HSG greater reduction; ", significance_label))
  }
  return(paste0("No difference; ", significance_label))
}
if (!lower_is_better) {
  if (estimate > 0) {
  return(paste0("Favours HSG greater increase; ", significance_label))
  }
  if (estimate < 0) {
  return(paste0("Favours non-HSG greater increase; ", significance_label))
  }
  return(paste0("No difference; ", significance_label))
}
"Not estimable"
}
