clean_marker_values<-function(x,marker_id,valid_min,valid_max) {
raw_num<-to_numeric_clean(x)
value<-rep(NA_real_,length(raw_num))
unit_inferred<-rep(NA_character_,length(raw_num))
if (marker_id == "hba1c") {
  percent_idx<-!is.na(raw_num) &
  raw_num >= HBA1C_PERCENT_MIN &
  raw_num <= HBA1C_PERCENT_MAX
  value[percent_idx]<-raw_num[percent_idx]
  unit_inferred[percent_idx] <- "NGSP_percent"
  mmol_mol_idx<-!is.na(raw_num) &
  raw_num > HBA1C_PERCENT_MAX &
  raw_num >= HBA1C_MMOL_MOL_MIN &
  raw_num <= HBA1C_MMOL_MOL_MAX
  if (AUTO_CONVERT_HBA1C_MMOL_MOL_TO_PERCENT) {
  value[mmol_mol_idx]<-convert_ifcc_to_ngsp_percent(raw_num[mmol_mol_idx])
  unit_inferred[mmol_mol_idx] <- "IFCC_mmol_per_mol_converted_to_NGSP_percent"
  }
} else {
  valid_idx<-!is.na(raw_num) &
  raw_num >= valid_min &
  raw_num <= valid_max
  value[valid_idx]<-raw_num[valid_idx]
  unit_inferred[valid_idx] <- "native_units"
}
final_valid<-!is.na(value) &
  is.finite(value) &
  value >= valid_min &
  value <= valid_max
value[!final_valid]<-NA_real_
unit_inferred[!final_valid]<-NA_character_
tibble::tibble(raw_numeric=raw_num,marker_value=value,unit_inferred=unit_inferred)
}
