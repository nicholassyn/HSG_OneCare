  return(!is.na(x))
}
if (inherits(x, "POSIXct") || inherits(x, "POSIXlt")) {
  return(!is.na(x))
}
x_chr<-as.character(x)
x_chr<-stringr::str_squish(x_chr)
x_upper<-stringr::str_to_upper(x_chr)
!is.na(x_chr) &
  x_chr != "" &
!(x_upper %in% c("NA","N/A","NULL","NONE","NIL","NAN","UNKNOWN","MISSING","NOT AVAILABLE","NOT APPLICABLE"))
}
