vc<-vc[beta_names,beta_names,drop=FALSE]
beta_sub<-beta[terms_to_test]
vc_sub<-vc[terms_to_test,terms_to_test,drop=FALSE]
chisq_value<-tryCatch(
  {
  as.numeric(t(beta_sub) %*% qr.solve(vc_sub,beta_sub))
  },
  error=function(e) {
  NA_real_
  }
)
df_value<-length(terms_to_test)
p_value<-ifelse(!is.na(chisq_value)&& is.finite(chisq_value)&& df_value > 0,stats::pchisq(chisq_value,df=df_value,lower.tail=FALSE),NA_real_)
tibble::tibble(marker_id=marker_id,marker_label=marker_label,test_label=test_label,terms_tested=paste(terms_to_test,collapse="; "),n_terms=df_value,chisq=chisq_value,df=df_value,p_value=p_value,p_print=fmt_p(p_value,digits=3),test_status=ifelse(is.na(p_value),"Failed","OK"))
}
