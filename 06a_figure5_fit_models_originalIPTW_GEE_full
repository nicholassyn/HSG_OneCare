}
compute_change_outlier_bounds<-function(x) {
x<-as.numeric(x)
x<-x[!is.na(x) & is.finite(x)]
if (!APPLY_CHANGE_OUTLIER_EXCLUSION || length(x) < OUTLIER_MIN_NONMISSING_VALUES) {
  return(
tibble::tibble(lower_bound=-Inf,upper_bound=Inf,q_lower=NA_real_,q_upper=NA_real_,iqr_lower=NA_real_,iqr_upper=NA_real_,n_values_used=length(x),outlier_method="No exclusion: insufficient values or disabled")
  )
}
q_lower<-as.numeric(
stats::quantile(x,probs=OUTLIER_LOWER_QUANTILE,na.rm=TRUE,names=FALSE,type=8)
)
q_upper<-as.numeric(
stats::quantile(x,probs=OUTLIER_UPPER_QUANTILE,na.rm=TRUE,names=FALSE,type=8)
)
q1<-as.numeric(
stats::quantile(x,probs=0.25,na.rm=TRUE,names=FALSE,type=8)
)
q3<-as.numeric(
stats::quantile(x,probs=0.75,na.rm=TRUE,names=FALSE,type=8)
)
iqr_value<-q3 - q1
iqr_lower<-q1 - OUTLIER_IQR_MULTIPLIER * iqr_value
iqr_upper<-q3 + OUTLIER_IQR_MULTIPLIER * iqr_value
lower_bound<-max(q_lower,iqr_lower,na.rm=TRUE)
upper_bound<-min(q_upper,iqr_upper,na.rm=TRUE)
if (!is.finite(lower_bound) || !is.finite(upper_bound) || lower_bound >= upper_bound) {
  lower_bound<-q_lower
  upper_bound<-q_upper
}
if (!is.finite(lower_bound) || !is.finite(upper_bound) || lower_bound >= upper_bound) {
  lower_bound<--Inf
  upper_bound<-Inf
}
tibble::tibble(lower_bound=lower_bound,upper_bound=upper_bound,q_lower=q_lower,q_upper=q_upper,iqr_lower=iqr_lower,iqr_upper=iqr_upper,n_values_used=length(x),outlier_method=paste0("Combined quantile/IQR on follow-up change: lower=max(q",OUTLIER_LOWER_QUANTILE,", Q1-",OUTLIER_IQR_MULTIPLIER,"*IQR); upper=min(q",OUTLIER_UPPER_QUANTILE,", Q3+",OUTLIER_IQR_MULTIPLIER,"*IQR)"))
}
create_time_basis<-function(data,requested_df=3) {
followup<-as.numeric(data$followup_months)
followup<-followup[is.finite(followup)]
if (length(unique(round(followup,6))) < 4) {
  data$followup_months_linear<-data$followup_months
  return(
list(data=data,basis_columns="followup_months_linear",basis_attributes=list(model_type="linear_time",knots=numeric(0),boundary_knots=range(followup,na.rm=TRUE),df=NA_integer_),use_spline=FALSE)
  )
}
nonzero_followup<-followup[followup > 0]
if (length(unique(round(nonzero_followup,6))) < 3) {
  data$followup_months_linear<-data$followup_months
  return(
list(data=data,basis_columns="followup_months_linear",basis_attributes=list(model_type="linear_time",knots=numeric(0),boundary_knots=range(followup,na.rm=TRUE),df=NA_integer_),use_spline=FALSE)
  )
}
