}
to_bool_from_csv<-function(x) {
if (is.logical(x)) {
  return(!is.na(x) & x)
}
if (is.numeric(x)) {
  return(!is.na(x) & x != 0)
}
x_chr<-stringr::str_to_lower(stringr::str_squish(as.character(x)))
x_chr[is.na(x_chr)] <- ""
positive<-x_chr %in% c("true","t","yes","y","1","present","recorded","done","completed")
negative<-x_chr %in% c("","false","f","no","n","0","absent","missing","na","n/a","null")
positive & !negative
}
fmt_n<-function(x) {
x_num<-suppressWarnings(as.numeric(x))
out <- rep("NA", length(x_num))
keep<-!is.na(x_num) & is.finite(x_num)
out[keep]<-scales::comma(x_num[keep],accuracy=1)
out
}
fmt_num<-function(x,digits=2) {
x_num<-suppressWarnings(as.numeric(x))
out <- rep("NA", length(x_num))
keep<-!is.na(x_num) & is.finite(x_num)
out[keep]<-formatC(
  x_num[keep],
  format = "f",
  digits=digits
)
out
}
fmt_p<-function(x,digits=3) {
x_num<-suppressWarnings(as.numeric(x))
out <- rep("NA", length(x_num))
keep<-!is.na(x_num) & is.finite(x_num)
very_small<-keep & x_num < 0.001
ordinary<-keep & x_num >= 0.001
out[very_small] <- "<0.001"
out[ordinary]<-formatC(
  x_num[ordinary],
  format = "f",
  digits=digits
)
out
}
fmt_ci<-function(estimate,conf_low,conf_high,digits=2) {
paste0(fmt_num(estimate,digits=digits)," (",fmt_num(conf_low,digits=digits)," to ",fmt_num(conf_high,digits=digits),")")
}
weighted_mean<-function(x,w) {
x<-as.numeric(x)
w<-as.numeric(w)
keep<-!is.na(x) & !is.na(w) & is.finite(x) & is.finite(w) & w > 0
if (!any(keep)) {
  return(NA_real_)
}
sum(w[keep] * x[keep]) / sum(w[keep])
}
