get_model_vcov<-function(fit) {
vc<-tryCatch(
  {
  stats::vcov(fit)
  },
  error=function(e) {
  NULL
  }
)
beta<-stats::coef(fit)
beta_names<-names(beta)
if (is.null(vc)) {
  vc<-fit$geese$vbeta
}
if (is.null(dim(vc))) {
  stop("Could not extract a valid variance-covariance matrix from the GEE model.")
}
if (is.null(colnames(vc)) || is.null(rownames(vc))) {
  rownames(vc)<-beta_names
  colnames(vc)<-beta_names
}
vc[beta_names,beta_names,drop=FALSE]
}
make_model_matrix_for_fit<-function(fit,newdata) {
terms_obj<-stats::delete.response(stats::terms(fit))
X<-stats::model.matrix(terms_obj,data=newdata)
beta_names<-names(stats::coef(fit))
missing_cols<-setdiff(beta_names,colnames(X))
if (length(missing_cols) > 0) {
  missing_matrix<-matrix(
  0,
  nrow=nrow(X),
  ncol=length(missing_cols)
  )
  colnames(missing_matrix)<-missing_cols
  X<-cbind(X,missing_matrix)
}
X[,beta_names,drop=FALSE]
}
predict_gee_identity<-function(fit,newdata) {
beta<-stats::coef(fit)
beta<-beta[!is.na(beta)]
vc<-get_model_vcov(fit)
vc<-vc[names(beta),names(beta),drop=FALSE]
X<-make_model_matrix_for_fit(fit,newdata)
X<-X[,names(beta),drop=FALSE]
fit_value<-as.numeric(X %*% beta)
pred_var<-rowSums((X %*% vc) * X)
pred_se<-sqrt(pmax(pred_var,0))
newdata %>% mutate(estimate=fit_value,std_error=pred_se,conf_low=estimate - stats::qnorm(0.975)* std_error,conf_high=estimate + stats::qnorm(0.975)* std_error)
}
contrast_gee_identity<-function(fit,newdata_a,newdata_b,contrast_label) {
beta<-stats::coef(fit)
beta<-beta[!is.na(beta)]
vc<-get_model_vcov(fit)
vc<-vc[names(beta),names(beta),drop=FALSE]
X_a<-make_model_matrix_for_fit(fit,newdata_a)
X_b<-make_model_matrix_for_fit(fit,newdata_b)
X_a<-X_a[,names(beta),drop=FALSE]
X_b<-X_b[,names(beta),drop=FALSE]
L<-X_a - X_b
estimate<-as.numeric(L %*% beta)
variance<-rowSums((L %*% vc) * L)
std_error<-sqrt(pmax(variance,0))
tibble::tibble(contrast=contrast_label,estimate=estimate,std_error=std_error,conf_low=estimate - stats::qnorm(0.975)* std_error,conf_high=estimate + stats::qnorm(0.975)* std_error,p_value=ifelse(std_error > 0 & is.finite(std_error),2 * stats::pnorm(abs(estimate / std_error),lower.tail=FALSE),NA_real_))
}
contrast_gee_average_identity<-function(
  fit,
  newdata_a,
  newdata_b,
  averaging_weights=NULL,
  contrast_label,
  estimand_type,
  averaging_method,
  horizon_start_month,
  horizon_end_month,
  unit_label,
  lower_is_better,
  n_support_patients_hsg=NA_real_,
  n_support_patients_nonhsg=NA_real_,
  n_support_rows=NA_real_
) {
beta<-stats::coef(fit)
beta<-beta[!is.na(beta)]
vc<-get_model_vcov(fit)
vc<-vc[names(beta),names(beta),drop=FALSE]
X_a<-make_model_matrix_for_fit(fit,newdata_a)
X_b<-make_model_matrix_for_fit(fit,newdata_b)
X_a<-X_a[,names(beta),drop=FALSE]
X_b<-X_b[,names(beta),drop=FALSE]
L<-X_a - X_b
if (nrow(L) == 0) {
  return(
tibble::tibble(contrast=contrast_label,estimand_type=estimand_type,averaging_method=averaging_method,horizon_start_month=horizon_start_month,horizon_end_month=horizon_end_month,horizon_duration_months=horizon_end_month - horizon_start_month,estimate=NA_real_,std_error=NA_real_,conf_low=NA_real_,conf_high=NA_real_,p_value=NA_real_,unit=unit_label,estimate_print="NA",p_print="NA",n_time_points=0L,n_averaging_rows=0L,n_support_patients_hsg=n_support_patients_hsg,n_support_patients_nonhsg=n_support_patients_nonhsg,n_support_rows=n_support_rows,interpretation="Not estimable")
  )
}
if (is.null(averaging_weights)) {
  averaging_weights<-rep(1,nrow(L))
}
averaging_weights<-as.numeric(averaging_weights)
valid_weight<-!is.na(averaging_weights) &
  is.finite(averaging_weights) &
  averaging_weights > 0
if (!any(valid_weight)) {
  return(
tibble::tibble(contrast=contrast_label,estimand_type=estimand_type,averaging_method=averaging_method,horizon_start_month=horizon_start_month,horizon_end_month=horizon_end_month,horizon_duration_months=horizon_end_month - horizon_start_month,estimate=NA_real_,std_error=NA_real_,conf_low=NA_real_,conf_high=NA_real_,p_value=NA_real_,unit=unit_label,estimate_print="NA",p_print="NA",n_time_points=nrow(L),n_averaging_rows=nrow(L),n_support_patients_hsg=n_support_patients_hsg,n_support_patients_nonhsg=n_support_patients_nonhsg,n_support_rows=n_support_rows,interpretation="Not estimable: no valid averaging weights")
  )
}
L<-L[valid_weight,,drop=FALSE]
averaging_weights<-averaging_weights[valid_weight]
averaging_weights<-averaging_weights / sum(averaging_weights)
L_bar<-colSums(L * averaging_weights)
estimate<-as.numeric(sum(L_bar * beta))
variance<-as.numeric(t(L_bar) %*% vc %*% L_bar)
std_error<-sqrt(max(variance,0))
conf_low<-estimate - stats::qnorm(0.975) * std_error
conf_high<-estimate + stats::qnorm(0.975) * std_error
p_value<-ifelse(std_error > 0 & is.finite(std_error),2 * stats::pnorm(abs(estimate / std_error),lower.tail=FALSE),NA_real_)
tibble::tibble(contrast=contrast_label,estimand_type=estimand_type,averaging_method=averaging_method,horizon_start_month=horizon_start_month,horizon_end_month=horizon_end_month,horizon_duration_months=horizon_end_month - horizon_start_month,estimate=estimate,std_error=std_error,conf_low=conf_low,conf_high=conf_high,p_value=p_value,unit=unit_label,estimate_print=fmt_ci(estimate=estimate,conf_low=conf_low,conf_high=conf_high,digits=2),p_print=fmt_p(p_value,digits=3),n_time_points=nrow(newdata_a),n_averaging_rows=nrow(L),n_support_patients_hsg=n_support_patients_hsg,n_support_patients_nonhsg=n_support_patients_nonhsg,n_support_rows=n_support_rows,interpretation=classify_effect_direction(estimate=estimate,p_value=p_value,lower_is_better=lower_is_better))
}
