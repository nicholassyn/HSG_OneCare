source("00_config.R"); source("01_common_definitions.R")
od<-file.path(OUT_DIR,"figure3_table2_raw"); dir.create(od,recursive=TRUE,showWarnings=FALSE)
fig3tab<-file.path(INTERNAL_OUTPUT_DIR,"Figure_3_ITS","tables_linear_counterfactual_stabilised")
res_path<-file.path(fig3tab,"ITS_all_processes_level_slope_results.csv")
mon_path<-file.path(fig3tab,"ITS_all_processes_monthly_summaries.csv")
if(!file.exists(res_path) || !file.exists(mon_path)) stop("Figure 3 stabilised result files not found. Run the final Figure 3 analysis first or place tables_linear_counterfactual_stabilised under Figure_3_ITS.")
res<-readr::read_csv(res_path,show_col_types=FALSE)
mon<-readr::read_csv(mon_path,show_col_types=FALSE)
ctrl<-res%>%filter(model_type=="Controlled ITS difference",comparison=="HSG minus Non-HSG")%>%select(process_id,process_label,contrast,estimate,conf_low,conf_high,p_value,estimate_print,ci_print,p_print)
lev<-ctrl%>%filter(contrast=="Level change")%>%select(process_id,level=estimate,level_low=conf_low,level_high=conf_high,level_p=p_value)
slp<-ctrl%>%filter(contrast=="Slope change")%>%select(process_id,slope=estimate,slope_low=conf_low,slope_high=conf_high,slope_p=p_value)
out<-ctrl%>%distinct(process_id,process_label)%>%left_join(lev,by="process_id")%>%left_join(slp,by="process_id")
write_csv(out,file.path(od,"figure3_ITS_estimates.csv")); write_csv(out,file.path(od,"table2_raw.csv"))
write_csv(mon,file.path(od,"figure3_monthly_model_data.csv"))
p1<-ggplot(mon,aes(as.Date(encounter_month),rate_percent,colour=comparison_group))+geom_point(size=.8)+geom_line()+facet_wrap(~process_label,scales="free_y")+geom_vline(xintercept=HSG_START_DATE,lty=2)+labs(x=NULL,y="Monthly rate (%)",colour=NULL,title="Raw monthly rates")
ggsave(file.path(od,"figure3_rates_raw.png"),p1,width=10,height=7,dpi=FIG_DPI)
# simple difference plot from monthly summaries
wide<-mon%>%select(process_id,process_label,encounter_month,comparison_group,rate_percent)%>%tidyr::pivot_wider(names_from=comparison_group,values_from=rate_percent)%>%mutate(diff=`HSG`-`Non-HSG`)
p2<-ggplot(wide,aes(as.Date(encounter_month),diff))+geom_point(size=.8)+geom_line()+facet_wrap(~process_label,scales="free_y")+geom_hline(yintercept=0,lty=3)+geom_vline(xintercept=HSG_START_DATE,lty=2)+labs(x=NULL,y="HSG minus non-HSG (%)",title="Raw monthly differences")
ggsave(file.path(od,"figure3_difference_raw.png"),p2,width=10,height=7,dpi=FIG_DPI)
file.create(file.path(OUT_DIR,"_DONE_figure3_table2.txt"))
