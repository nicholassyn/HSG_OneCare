source("00_config.R"); source("01_common_definitions.R")
od<-file.path(OUT_DIR,"figure4_IPTW_raw"); dir.create(od,recursive=TRUE,showWarnings=FALSE)
fig4tab<-file.path(INTERNAL_OUTPUT_DIR,"Figure_4_IPTW_IRD_forest","tables")
fig4diag<-file.path(INTERNAL_OUTPUT_DIR,"Figure_4_IPTW_IRD_forest","diagnostics")
res_path<-file.path(fig4tab,"Figure_4_IPTW_IRD_manuscript_results_compact.csv")
def_path<-file.path(fig4tab,"Figure_4_endpoint_definitions.csv")
ps_sum<-file.path(fig4diag,"Figure_4_propensity_score_weight_diagnostics.csv")
ps_bal<-file.path(fig4diag,"Figure_4_IPTW_covariate_balance_SMD.csv")
if(!file.exists(res_path)) stop("Final Figure 4 compact result file not found.")
res<-readr::read_csv(res_path,show_col_types=FALSE)
if(file.exists(def_path)) file.copy(def_path,file.path(od,"figure4_endpoint_definitions_public.csv"),overwrite=TRUE)
if(file.exists(ps_sum)) file.copy(ps_sum,file.path(od,"PS_weight_summary.csv"),overwrite=TRUE)
if(file.exists(ps_bal)) file.copy(ps_bal,file.path(od,"PS_balance_basic_SMD.csv"),overwrite=TRUE)
overall<-res%>%filter(subgroup_label=="Overall")%>%transmute(endpoint_id=make.names(endpoint_label),endpoint=endpoint_label,estimate=ird_events_per_person_year,conf_low=ci_low_events_per_person_year,conf_high=ci_high_events_per_person_year,p_value=p_value,n=n_total)
write_csv(overall,file.path(od,"figure4_IPTW_results_raw.csv"))
p<-ggplot(overall,aes(estimate,reorder(endpoint,estimate)))+geom_vline(xintercept=0,lty=2)+geom_errorbarh(aes(xmin=conf_low,xmax=conf_high),height=.2)+geom_point()+labs(x="Adjusted incidence-rate difference",y=NULL,title="Raw IPTW incidence-rate differences")
ggsave(file.path(od,"figure4_raw_forest.png"),p,width=8,height=6,dpi=FIG_DPI)
# copy patient-level weights if present so Figure 5 public script can either use it or document source
wpath<-file.path(fig4diag,"Figure_4_patient_level_with_propensity_scores_and_IPTW.csv")
if(file.exists(wpath)) {
  w<-readr::read_csv(wpath,show_col_types=FALSE)%>%select(any_of(c("patient","hsg_exposed","comparison_group","iptw_final","person_time_years","clinic")))
  saveRDS(w,file.path(od,"_weights_for_figure5.rds"))
}
file.create(file.path(OUT_DIR,"_DONE_figure4_IPTW_clinicFE.txt"))
