read_clean_data<-function(restrict_study_dates=FALSE, ignore_post_end_enrol=FALSE){
 raw<-readr::read_csv(DATA_PATH,guess_max=500000,show_col_types=FALSE,na=c("","NA","N/A","NULL","NaN","nan"))%>%janitor::clean_names()
 if(!"enrolment_date"%in%names(raw)&&"enrollment_date"%in%names(raw)) raw$enrolment_date<-raw$enrollment_date
 if(!"de_enrolment_date"%in%names(raw)&&"de_enrollment_date"%in%names(raw)) raw$de_enrolment_date<-raw$de_enrollment_date
 req<-c("patient","clinic","encounter_kind","encounter_date","enrolment_date","de_enrolment_date","annual_health_plan","c_year_of_birth","citizenship_status","gender","ethnicity","patient_chas_type","smoker")
 for(x in req) if(!x%in%names(raw)) raw[[x]]<-NA
 date_cols<-names(raw)[grepl("date",names(raw))|names(raw)%in%c("encounter_date","enrolment_date","de_enrolment_date")]
 for(x in date_cols) raw[[x]]<-parse_mixed_date(raw[[x]])
 raw<-raw%>%filter(!is.na(encounter_date))%>%mutate(patient=as.character(patient),clinic=as.character(clinic),c_year_of_birth_numeric=to_num(c_year_of_birth),encounter_month=lubridate::floor_date(encounter_date,"month"))
 if(ignore_post_end_enrol) raw<-raw%>%mutate(enrolment_date=ifelse(enrolment_date>STUDY_END_DATE,NA,enrolment_date),de_enrolment_date=ifelse(de_enrolment_date>STUDY_END_DATE,NA,de_enrolment_date),enrolment_date=as.Date(enrolment_date,origin="1970-01-01"),de_enrolment_date=as.Date(de_enrolment_date,origin="1970-01-01"))
 if(restrict_study_dates) raw<-raw%>%filter(encounter_date>=STUDY_START_DATE,encounter_date<=STUDY_END_DATE)
 add_service_flags(raw)
}

