parse_mixed_date<-function(x){
 if(inherits(x,"Date")) return(x); if(inherits(x,"POSIXct")||inherits(x,"POSIXlt")) return(as.Date(x))
 if(is.numeric(x)){out<-rep(as.Date(NA),length(x)); ii<-!is.na(x)&x>20000&x<70000; out[ii]<-as.Date(x[ii],origin="1899-12-30"); return(out)}
 z<-stringr::str_squish(as.character(x)); z[is.na(z)|z==""|toupper(z)%in%c("NA","N/A","NULL","NONE","NIL","NAN","UNKNOWN","MISSING")]<-NA
 y<-suppressWarnings(lubridate::parse_date_time(z,orders=c("ymd HMS","ymd HM","ymd","dmy HMS","dmy HM","dmy","mdy HMS","mdy HM","mdy","d b Y","d B Y","d-b-Y","d-B-Y","m/d/Y","m/d/y","d/m/Y","d/m/y","Y/m/d"),tz="UTC",quiet=TRUE))
 out<-as.Date(y); num<-suppressWarnings(as.numeric(z)); ii<-is.na(out)&!is.na(num)&num>20000&num<70000; out[ii]<-as.Date(num[ii],origin="1899-12-30"); out
}
is_present<-function(x){ if(inherits(x,"Date")) return(!is.na(x)); z<-stringr::str_squish(as.character(x)); u<-toupper(z); !is.na(z)&z!=""&!(u%in%c("NA","N/A","NULL","NONE","NIL","NAN","UNKNOWN","MISSING")) }
to_num<-function(x){if(is.numeric(x)) x else suppressWarnings(readr::parse_number(as.character(x)))}
safe_min_date<-function(x){x<-as.Date(x); x<-x[!is.na(x)]; if(length(x)==0) as.Date(NA) else min(x)}
safe_max_date<-function(x){x<-as.Date(x); x<-x[!is.na(x)]; if(length(x)==0) as.Date(NA) else max(x)}
first_present_value<-function(x){ii<-is_present(x); if(!any(ii,na.rm=TRUE)) NA_character_ else as.character(x[ii][1])}
mode_present_value<-function(x){ii<-is_present(x); if(!any(ii,na.rm=TRUE)) NA_character_ else names(sort(table(as.character(x[ii])),decreasing=TRUE))[1]}
yesno<-function(x){ if(is.logical(x)) return(!is.na(x)&x); if(is.numeric(x)) return(!is.na(x)&x!=0); z<-tolower(stringr::str_squish(as.character(x))); z[is.na(z)]<-""; grepl("^(1|yes|true|y|done|completed|complete|positive|present|recorded)$",z)&!grepl("^(0|no|false|n|nil|none|not done|not completed|incomplete|negative)$",z)}
cond_bool<-function(x){ if(is.logical(x)) return(!is.na(x)&x); if(is.numeric(x)) return(!is.na(x)&x!=0); z<-tolower(stringr::str_squish(as.character(x))); z[is.na(z)]<-""; neg<-z%in%c("","na","n/a","unknown","none","nil","no","0","false","negative","absent"); (grepl("^(1|yes|true|y|present|positive|diagnosed|known)$",z)|!neg)&!neg }
enrol_bool<-function(x){z<-tolower(stringr::str_squish(as.character(x))); z[is.na(z)]<-""; grepl("enrolled|enroled|enrol|enroll",z)&!grepl("not enrolled|non-enrolled|non enrolled|unenrolled|de-enrolled|de enrolled|de-enrol|de enrol|withdraw|terminated|ceased",z)}
deenrol_bool<-function(x){z<-tolower(stringr::str_squish(as.character(x))); z[is.na(z)]<-""; grepl("de-enrolled|de enrolled|de-enroled|de enroled|de-enrol|de enrol|de-enroll|de enroll|withdraw|withdrawn|terminated|ceased",z)}
row_any_present<-function(d,cc){cc<-intersect(cc,names(d)); if(!length(cc)) return(rep(FALSE,nrow(d))); m<-vapply(cc,function(x)is_present(d[[x]]),logical(nrow(d))); if(is.null(dim(m))) m<-matrix(m,ncol=1); rowSums(m,na.rm=TRUE)>0}
row_any_pattern<-function(d,cc,pat){cc<-intersect(cc,names(d)); if(!length(cc)) return(rep(FALSE,nrow(d))); m<-vapply(cc,function(x){z<-tolower(stringr::str_squish(as.character(d[[x]]))); z[is.na(z)]<-""; grepl(pat,z)},logical(nrow(d))); if(is.null(dim(m))) m<-matrix(m,ncol=1); rowSums(m,na.rm=TRUE)>0}
row_any_vax<-function(d,cc,codes){cc<-intersect(cc,names(d)); if(!length(cc)) return(rep(FALSE,nrow(d))); codes<-unique(toupper(stringr::str_squish(codes))); codes<-codes[order(nchar(codes),decreasing=TRUE)]; pat<-paste0("(^|[^A-Z0-9])(",paste(codes,collapse="|"),")([^A-Z0-9]|$)"); m<-vapply(cc,function(x){z<-toupper(stringr::str_squish(as.character(d[[x]]))); z[is.na(z)]<-""; grepl(pat,z)},logical(nrow(d))); if(is.null(dim(m))) m<-matrix(m,ncol=1); rowSums(m,na.rm=TRUE)>0}
row_any_enrol<-function(d,cc){cc<-intersect(cc,names(d)); if(!length(cc)) return(rep(FALSE,nrow(d))); m<-vapply(cc,function(x)enrol_bool(d[[x]]),logical(nrow(d))); if(is.null(dim(m))) m<-matrix(m,ncol=1); rowSums(m,na.rm=TRUE)>0}
row_any_deenrol<-function(d,cc){cc<-intersect(cc,names(d)); if(!length(cc)) return(rep(FALSE,nrow(d))); m<-vapply(cc,function(x)deenrol_bool(d[[x]]),logical(nrow(d))); if(is.null(dim(m))) m<-matrix(m,ncol=1); rowSums(m,na.rm=TRUE)>0}
elig_citizen<-function(x){z<-toupper(stringr::str_squish(as.character(x))); miss<-!is_present(z); foreign<-grepl("FOREIGN|FOREIGNER|WORK PASS|WORKPASS|WORK PERMIT|EMPLOYMENT PASS|\\bE PASS\\b|\\bEP\\b|S PASS|SPASS|DEPENDANT PASS|DEPENDENT PASS|LONG.?TERM VISIT PASS|LTVP",z); local<-grepl("SINGAPOREAN|SINGAPORE CITIZEN|CITIZEN|SINGAPORE PR|SINGAPORE PERMANENT RESIDENT|PERMANENT RESIDENT|\\bPR\\b",z); local|(!foreign&!miss)|(KEEP_PATIENTS_WITH_MISSING_CITIZENSHIP&miss)}
clean_gender<-function(x){z<-toupper(stringr::str_squish(as.character(x))); dplyr::case_when(grepl("^F$|FEMALE|WOMAN",z)~"Female",grepl("^M$|^MALE$|MAN",z)~"Male",TRUE~"Unknown")}
clean_eth<-function(x){z<-toupper(stringr::str_squish(as.character(x))); dplyr::case_when(grepl("CHINESE",z)~"Chinese",grepl("MALAY",z)~"Malay",grepl("INDIAN",z)~"Indian",z==""|is.na(z)|z=="UNKNOWN"~"Other",TRUE~"Other")}
clean_cit<-function(x){z<-toupper(stringr::str_squish(as.character(x))); dplyr::case_when(grepl("PERMANENT RESIDENT|\\bPR\\b",z)~"Permanent resident",grepl("CITIZEN|SINGAPOREAN",z)~"SG Citizen",TRUE~"Unknown")}
clean_chas<-function(x){z<-toupper(stringr::str_squish(as.character(x))); dplyr::case_when(grepl("BLUE",z)~"CHAS Blue",grepl("ORANGE",z)~"CHAS Orange",grepl("GREEN",z)~"CHAS Green",TRUE~"No/Other CHAS")}
smoke_grp<-function(x){z<-toupper(stringr::str_squish(as.character(x))); dplyr::case_when(grepl("EX",z)~"Ex-smoker",grepl("CURRENT",z)~"Current smoker",grepl("NEVER",z)~"Never smoker",TRUE~"Unknown")}
collapse_rare<-function(x,min_n=50,other="Other/rare clinic"){x<-as.character(x); x[!is_present(x)]<-"Unknown"; tt<-table(x); x[!(x%in%names(tt)[tt>=min_n])]<-other; factor(x)}

