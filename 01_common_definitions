make_pt<-function(d,split_iaib=FALSE){
 p<-make_patient_level(d)
 pre<-d%>%filter(encounter_date < HSG_START_DATE)%>%group_by(patient)%>%summarise(pre_hsg_unique_encounter_dates=n_distinct(encounter_date),pre_hsg_encounter_rows=n(),.groups="drop")
 p<-p%>%left_join(pre,by="patient")%>%mutate(pre_hsg_unique_encounter_dates=replace_na(pre_hsg_unique_encounter_dates,0L),pre_hsg_encounter_rows=replace_na(pre_hsg_encounter_rows,0L),population_group=population_short,hsg_pathway=population_group%in%c("I","III"),patient_female_flag=female,patient_vaccination_eligible_flag=vaccination_eligible_flag,obs_start=if_else(hsg_pathway,first_valid_enrolment_reference_date,first_encounter_date),obs_start=pmax(obs_start,STUDY_START_DATE),obs_end=if_else(hsg_pathway & !is.na(first_deenrolment_event_date) & first_deenrolment_event_date<=STUDY_END_DATE,first_deenrolment_event_date,STUDY_END_DATE))
 p
}
